# Claude API (required)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Data refresh
AUTO_REFRESH=true
REFRESH_SCHEDULE=0 2 * * *

# Storage
DATA_DIR=./data
AUDIT_RETENTION_DAYS=2555

# Matching thresholds
FUZZY_THRESHOLD=60
MAX_CANDIDATES=20

# Server
HOST=0.0.0.0
PORT=8080

# Optional: disable specific sources
# DISABLED_SOURCES=au_dfat,interpol_red
